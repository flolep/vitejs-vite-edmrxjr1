# Copier ce fichier en .env.local et remplir avec vos vraies valeurs
# Le fichier .env.local ne sera jamais commité (dans .gitignore)

# Clé API Hostinger
# Obtenir sur: https://hpanel.hostinger.com → API
HOSTINGER_API_KEY=hpanel_your_api_key_here

# Nom du conteneur Docker à vérifier (optionnel, par défaut: n8n)
DOCKER_CONTAINER_NAME=n8n
